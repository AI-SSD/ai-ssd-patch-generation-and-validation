{
  "name": "cve-pipeline-dashboard",
  "version": "1.0.0",
  "description": "Dashboard for analyzing CVE patch generation pipeline results",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
